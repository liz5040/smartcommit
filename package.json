{
  "name": "smartcommit",
  "displayName": "SmartCommit",
  "description": "AI-powered commit message generator",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
"contributes": {
    "commands": [
    {
        "command": "smartcommit.generateCommit",
        "title": "SmartCommit: Generate Commit Message"
    },
    {
        "command": "smartcommit.generatePR",
        "title": "SmartCommit: Generate PR Description"
    }
],
    "viewsContainers": {
        "activitybar": [
            {
                "id": "smartcommit-sidebar",
                "title": "SmartCommit",
                "icon": "$(git-commit)"
            }
        ]
    },
    "views": {
        "smartcommit-sidebar": [
            {
                "type": "webview",
                "id": "smartcommit.sidebar",
                "name": "SmartCommit"
            }
        ]
    }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "groq-sdk": "^1.2.0",
    "simple-git": "^3.36.0"
  }
}
